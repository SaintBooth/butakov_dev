{
  "name": "butakov-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-llms-txt.js && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "images": "node scripts/convert-images.js",
    "prepare": "husky"
